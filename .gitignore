# .gitignore - Files to exclude from Git

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Data files (large)
# Uncomment if you want to exclude data files from Git:
# data/historical/*.csv
# models/*.keras
# models/*.pkl

# Temporary
*.tmp
*.temp
*.log
*.cache

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Credentials (NEVER commit these!)
credentials.json
*.key
*.pem
AWS_credentials.csv
